# GroktoCrawl runtime configuration
# Copy this to .env and adjust for your deployment.

# LLM provider (required for real use; defaults to self-contained fixture)
# LLM_API_KEY=
# LLM_BASE_URL=http://llm-svc:8011/v1
# LLM_MODEL=fixture-model

# Example: DeepSeek
# LLM_API_KEY=sk-your-deepseek-key
# LLM_BASE_URL=https://api.deepseek.com/v1
# LLM_MODEL=deepseek-v4-flash

# Example: OpenAI
# LLM_API_KEY=sk-your-openai-key
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini

# Example: Ollama (local)
# LLM_BASE_URL=http://host.docker.internal:11434/v1
# LLM_MODEL=llama3.2

# Internal service URLs (override only if running services separately)
# VALKEY_URL=redis://valkey:6379/0
# SEARXNG_URL=http://searxng:8080
# SCRAPER_URL=http://scraper-svc:8001
