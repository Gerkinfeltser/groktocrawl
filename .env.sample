# GroktoCrawl runtime configuration
# Copy this to .env and adjust for your deployment.

# LLM provider (required for real use; fixture works for demo)
LLM_API_KEY=test-key
LLM_BASE_URL=http://llm-svc:8011/v1
LLM_MODEL=fixture-model

# Optional: API key to protect the agent-svc endpoint
# API_KEY=

# Internal service URLs (override only if running services externally)
# VALKEY_URL=redis://valkey:6379/0
# SEARXNG_URL=http://search-svc:8010
# SCRAPER_URL=http://scraper-svc:8001
